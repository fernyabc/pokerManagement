# Backend environment variables
# Copy this file to .env and fill in your values

# OpenAI API key for LLM reasoning (optional — falls back to static charts if unset)
OPENAI_API_KEY=sk-...

# Database URL (default: async SQLite in current directory)
DATABASE_URL=sqlite+aiosqlite:///./poker_hands.db

# Path to TexasSolver console_solver binary (optional — uses mock solver if unset)
TEXAS_SOLVER_BIN=/usr/local/bin/console_solver

# Path to the pre-computed GTO solution cache database
CACHE_DB_PATH=gto_cache.db
